# Secrets
.env
.env.*
!.env.template

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build / cache
build/
dist/
.coverage
htmlcov/

# Database — Phase 1 commits trader.db back on every cron run (Option A
# per decision-log entry 2026-05-17). All other SQLite files stay ignored
# (test temporaries, journals, scratch DBs).
*.db
!trader.db
*.db-journal
*.sqlite
*.sqlite3

# Reports / runs (these accumulate; commit only the canonical
# ones, not every run artifact)
runs/*.log

# VPS cron logs — written on the Hetzner box, never committed back
vps/logs/*.log

# Local UI reference material
html/

# Editor / local tool state
*.code-workspace
.claude/settings.local.json
